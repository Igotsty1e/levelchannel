# ── Security headers ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set X-DNS-Prefetch-Control "off"
    # Content-Security-Policy intentionally NOT set here. Production runs
    # nginx + Next.js (systemd, ops/.../nginx) — Apache/.htaccess is inert
    # on this deploy. The single source of truth for CSP is the per-request
    # nonce policy assembled in `proxy.ts` + `lib/security/csp.ts`. The old
    # static `script-src 'self' 'unsafe-inline' …` line that lived here was
    # a divergent second policy (it allowed inline scripts the nonce policy
    # blocks) — removed 2026-06-27 to kill the drift. If this app is ever
    # served by Apache, re-derive CSP from `lib/security/csp.ts`, do NOT
    # re-introduce `'unsafe-inline'`.
</IfModule>

# ── Apache hardening (no autoindex) ───────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    Options -Indexes
    # 2026-06-16: Removed two RewriteRule entries that forced
    # /privacy → /privacy/ and /offer → /offer/ with R=301.
    # Reason: Next.js App Router (no `trailingSlash` set in
    # next.config.js → defaults to FALSE) serves these pages
    # canonically without trailing slash, and the sitemap entries
    # use no-slash form. The Apache 301 made Googlebot see the
    # canonical URL as a redirect; Search Console marked
    # /privacy and /offer as «Страница с переадресацией» (page
    # with redirect → not indexed). Do not re-add unless
    # next.config.js gets `trailingSlash: true` first.
</IfModule>

# ── Cache static assets ────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                  "access plus 1 hour"
    ExpiresByType text/css                   "access plus 1 year"
    ExpiresByType application/javascript     "access plus 1 year"
    ExpiresByType image/jpeg                 "access plus 1 year"
    ExpiresByType image/png                  "access plus 1 year"
    ExpiresByType image/webp                 "access plus 1 year"
    ExpiresByType font/woff2                 "access plus 1 year"
</IfModule>

# ── Compression ────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# ── Hide server signature ──────────────────────────────────────
ServerSignature Off
