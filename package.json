{
  "name": "levelchannel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:export": "next build && node postbuild.js",
    "start": "next start",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "bash scripts/test-integration.sh",
    "test:integration:coverage": "LC_INTEGRATION_COVERAGE=1 bash scripts/test-integration.sh --coverage",
    "migrate:up": "node scripts/migrate.mjs up",
    "migrate:status": "node scripts/migrate.mjs status",
    "migrate:payments:postgres": "node scripts/migrate-payment-orders-to-postgres.mjs",
    "check:env-contract": "node scripts/check-env-contract.mjs",
    "check:content-style": "node scripts/check-content-style.mjs",
    "test:e2e:seed": "node tests/e2e/seed.mjs",
    "test:e2e:product-flows": "next build && playwright test --config=playwright.config.ts",
    "test:e2e:product-flows:only": "playwright test --config=playwright.config.ts",
    "test:mutation": "stryker run",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.55.0",
    "bcryptjs": "^3.0.3",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "resend": "^6.12.4"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.0.1",
    "jsdom": "^29.1.1",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
