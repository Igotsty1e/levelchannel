#!/usr/bin/env bash
#
# commit-msg hook — runs repo-level guardrails in series.
# Activated by `git config core.hooksPath .githooks` (set automatically
# via `npm install` postinstall, or manually with the same command).
#
# Each delegated script contains its own shared matching/trailer logic
# reused by the corresponding CI workflow. Run order matches the order
# of failure cost: legal trailer (regulatory) before skill trailer
# (process). Both must clear for the commit to land.

set -e
root="$(git rev-parse --show-toplevel)"

"$root/scripts/legal-pipeline-check.sh" --commit-msg "$1"
"$root/scripts/skill-pipeline-check.sh" --commit-msg "$1"
