PAYMENTS_PROVIDER=mock
PAYMENTS_STORAGE_BACKEND=file
PAYMENTS_STORAGE_FILE=payment-orders.json
PAYMENTS_MOCK_AUTO_CONFIRM_SECONDS=20
PAYMENTS_ALLOW_MOCK_CONFIRM=true
# В проде НЕ ставить true — иначе POST /api/payments/mock/[invoiceId]/confirm
# сможет перевести любой ордер в paid без оплаты.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_LEGAL_OPERATOR_NAME=
NEXT_PUBLIC_LEGAL_OPERATOR_DISPLAY=
NEXT_PUBLIC_LEGAL_OPERATOR_TAX_ID=
NEXT_PUBLIC_LEGAL_OPERATOR_OGRN=
NEXT_PUBLIC_LEGAL_OPERATOR_REG_AUTHORITY=
NEXT_PUBLIC_LEGAL_OPERATOR_CLAIMS_ADDRESS=
NEXT_PUBLIC_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_LEGAL_BANK_ACCOUNT=
NEXT_PUBLIC_LEGAL_BANK_NAME=
NEXT_PUBLIC_LEGAL_BANK_BIK=
NEXT_PUBLIC_LEGAL_BANK_CORR_ACCOUNT=
NEXT_PUBLIC_LEGAL_BANK_CITY=
DATABASE_URL=

# Postgres TLS policy (Wave 1.1 — security). Auto-detect by URL host:
#   - localhost / 127.0.0.1 / ::1 / *.local → no TLS (loopback;
#     single-server deploys with Postgres on the same box are valid)
#   - every other host → strict TLS with cert verification
#     (`ssl: { rejectUnauthorized: true }`)
# The JS-side ssl option overrides any URL-level `?sslmode=` hint.
#
# DB_SSL pinning:
#   - require / on / true     → strict TLS even on localhost
#   - disable / off / false   → no TLS (rejected in production for
#     non-local hosts only — disabling TLS on a remote Postgres in
#     prod is the actual leak; on the loopback path it's a no-op)
#   - unset                   → auto-detect
#
# DB_SSL_REJECT_UNAUTHORIZED=false → encrypted-but-lax cert check.
# Rejected in production for non-local hosts. Allowed on localhost or
# in dev (e.g. when targeting a managed host with a self-signed cert).
DB_SSL=
DB_SSL_REJECT_UNAUTHORIZED=

TELEMETRY_HASH_SECRET=

# Switch PAYMENTS_PROVIDER to cloudpayments when credentials are ready.
# Public ID is used by the CloudPayments widget on the client side.
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=

# Resend transactional email — used for verify + reset.
# When RESEND_API_KEY is empty, sendEmail falls back to console.log so
# you can still register/reset locally without standing up Resend.
# In production lib/email/config.ts throws on boot if this is empty.
RESEND_API_KEY=
# EMAIL_FROM must use a Resend-verified domain in production.
# `onboarding@resend.dev` is Resend's sandbox sender — it ONLY delivers
# to the Resend account owner's email. Real users won't get verify /
# reset / operator-notification emails through it. For prod, verify
# your own domain in Resend (DNS: SPF, DKIM, MX) and set:
#   EMAIL_FROM="LevelChannel <noreply@mail.your-domain>"
# Levelchannel prod uses `noreply@mail.levelchannel.ru` (domain
# verified 2026-05-07).
EMAIL_FROM="LevelChannel <noreply@mail.levelchannel.ru>"

# HMAC key for per-email rate-limit scope strings (lib/auth/email-hash.ts).
# 32+ random chars. NOT the same value as TELEMETRY_HASH_SECRET — different
# trust boundary, different rotation cadence (see /plan-eng-review mech-3).
# In production lib/email/config.ts throws on boot if this is empty.
AUTH_RATE_LIMIT_SECRET=

# SAAS-3+4 TINV.1 (2026-05-18) — HMAC key for teacher invite tokens.
# 32+ random chars. Generate with `openssl rand -base64 48`. NOT the
# same value as AUTH_RATE_LIMIT_SECRET — different trust boundary,
# different rotation cadence. lib/auth/teacher-invites.ts reads this
# per-call (no module-scope cache) so rotation takes effect on the
# next request. In production lib/auth/teacher-invites.ts throws on
# every call if this is unset (boot-fail-on-first-use).
# Rotation effect: outstanding invites signed with the old secret
# will be rejected. Document expected blast radius before rotating.
TEACHER_INVITE_SECRET=

# Email destination for operator notifications:
# - successful CloudPayments Pay webhook → "Платёж получен" email
#   (sent inline from /api/payments/webhooks/cloudpayments/pay; best-effort).
# When empty, operator emails are silently skipped.
OPERATOR_NOTIFY_EMAIL=

# Sentry error tracking (instrumentation.ts + instrumentation-client.ts).
# Empty values turn the SDK into a no-op (dev-friendly). In production,
# set both to the project DSN copied from Sentry → Settings → Projects →
# levelchannel → Client Keys (DSN). The two vars exist because the
# server-side path doesn't need to be exposed in the public bundle:
#   - SENTRY_DSN: read by instrumentation.ts (Node + Edge runtimes)
#   - NEXT_PUBLIC_SENTRY_DSN: read by instrumentation-client.ts (browser)
# Both can hold the same DSN value; separate vars just mean you can
# scope the client one off independently if needed.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload (optional). When set, the build pipeline
# uploads source maps so stack traces in the Sentry UI deobfuscate to
# real filenames + line numbers. Without it, stack traces still arrive
# but reference bundled JS — readable enough for v1. Token is created
# at Sentry → Settings → Auth Tokens with `project:releases` scope.
SENTRY_AUTH_TOKEN=

# Audit log at-rest encryption (Wave 2.1 — security).
# Mandatory in production. ≥32 random characters. Encrypts the
# `customer_email` and `client_ip` columns of `payment_audit_events`
# via pgcrypto's pgp_sym_encrypt. Generate with:
#
#   openssl rand -base64 48
#
# WARNING: this key is the only thing that makes a DB-dump leak useless
# (Phase B onward, see ENGINEERING_BACKLOG.md). Treat it as a peer of
# CLOUDPAYMENTS_API_SECRET for rotation cadence. Losing this key means
# losing every encrypted audit row — there is no recovery path.
#
# `lib/audit/encryption.ts` throws on first use under NODE_ENV=production
# if this is empty or shorter than 32 characters.
AUDIT_ENCRYPTION_KEY=

# AUDIT_ENCRYPTION_KEY_OLD (Wave 3.1 — security, optional).
# The PREVIOUS encryption key, set ONLY during a rotation window. The
# reader tries AUDIT_ENCRYPTION_KEY first; on decrypt failure (different
# key), falls back to AUDIT_ENCRYPTION_KEY_OLD via the
# pgp_sym_decrypt_either SQL helper (migration 0027).
#
# Operator runbook (SECURITY.md § At-rest encryption — Key rotation):
#   day 0:   set AUDIT_ENCRYPTION_KEY=<new>, AUDIT_ENCRYPTION_KEY_OLD=<previous>
#            restart app. New rows encrypt with NEW; reads work for both.
#   day N:   run scripts/rotate-audit-encryption.mjs to re-encrypt every
#            legacy row from OLD to PRIMARY. Idempotent.
#   day N+1: drop AUDIT_ENCRYPTION_KEY_OLD from env. Restart. Done.
#
# Length floor (32 chars) applies if set. Missing is fine in any env.
AUDIT_ENCRYPTION_KEY_OLD=

# BCS-OP-ROLLOUT — Calendar cron route shared secret.
# Authenticates loopback POSTs to /api/cron/calendar/* (pull, push,
# intents, renew-channels, revive-blocked, reconcile). The activator
# script `scripts/activate-prod-ops.sh` auto-generates a 32-char hex
# secret on first run and appends to $ENV_FILE if missing.
#
# Two-layer gate (lib/api/cron-auth.ts):
#   1. Loopback-Host check (route returns 404 on Host mismatch)
#   2. Bearer secret match (401 on mismatch)
#
# Rotation: change here + restart `levelchannel.service` + update
# the cron-runner env (where calendar-cron.mjs reads it). New secret
# picked up on next tick.
CRON_SHARED_SECRET=

# BCS-OP-ROLLOUT — optional comma-separated list of EXTRA hostnames
# allowed through the cron-route Host gate. Loopback (127.0.0.1,
# localhost, ::1) is always allowed; this is for non-standard
# deployments where the systemd timer would call via a different
# hostname. Leave empty for the standard single-VPS layout.
CRON_TRUSTED_HOST=

# BCS-DEF-1-TG (2026-05-19) — Telegram alert channel for the 4
# operator-side systemd probes (auth-flow, calendar-pathology,
# webhook-flow, conflict-unresolved). Plan:
# docs/plans/bcs-def-1-tg-telegram-alerts.md.
#
# Setup (operator-runbook):
#   1. @BotFather → /newbot → token below.
#   2. /start the bot from the target Telegram account.
#   3. curl "https://api.telegram.org/bot$TG/getUpdates" |
#        jq '.result[-1].message.chat.id'
#      → chat-id below.
#   4. Append both lines to the prod $ENV_FILE the autodeploy runner
#      manages (same file the existing RESEND_API_KEY / ALERT_EMAIL_TO
#      lines live in). No env.d/ fan-out — single-file contract.
#   5. systemctl restart levelchannel + the 4 probe timers, then flip
#      TELEGRAM_ALERTS_MASTER_SWITCH=1 via /admin/settings/alerts.
#
# OFF by default — channel stays dormant until the master switch flips,
# so this PR ships without forcing BotFather setup pre-merge.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# BCS-DEF-4-TG (2026-05-20) — Telegram webhook secret for learner
# bind handshake. Required when LEARNER_REMINDERS_TELEGRAM_ENABLED=1.
# Generate via `openssl rand -hex 32`. Must match the secret_token
# passed to Telegram's setWebhook on activation. Bot username (no @)
# is optional but enables the deep-link UI in the cabinet.
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_BOT_USERNAME=

# PAY-SBP-REMOVAL (2026-05-20) — operator gate for the SBP QR route.
# The /pay UI button was removed because the CloudPayments merchant
# terminal doesn't have SBP activated yet. Set to literal 'true' to
# revive the POST /api/payments/sbp/create-qr endpoint when CP-side
# activation lands. Any other value (including '1', 'yes', empty)
# keeps the route returning 503 sbp_disabled. Exact-match guard.
SBP_ENABLED=false
